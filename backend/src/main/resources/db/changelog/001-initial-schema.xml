<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-04-17 Loan application table" author="Markus Käpp">
        <createTable tableName="loan_application"
                     remarks="Stores loan applications submitted by customers, including personal data, loan terms, and application status">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="first_name" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>

            <column name="last_name" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>

            <column name="personal_code" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>

            <column name="birth_date" type="DATE"/>

            <column name="loan_period_months" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="interest_margin" type="NUMERIC(5,3)">
                <constraints nullable="false"/>
            </column>

            <column name="base_interest_rate" type="NUMERIC(5,3)">
                <constraints nullable="false"/>
            </column>

            <column name="loan_amount" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="rejection_reason" type="VARCHAR(50)"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2026-04-17 Loan status constraint" author="Markus Käpp">
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_status
                    CHECK (status IN ('NEW','IN_REVIEW','APPROVED','REJECTED'));
        </sql>
    </changeSet>

    <changeSet id="2026-04-17 Personal code format constraint" author="Markus Käpp">
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_personal_code_format
                    CHECK (personal_code ~ '^[1-6][0-9]{10}$');
        </sql>
    </changeSet>

    <changeSet id="2026-04-17 Active loan unique index" author="Markus Käpp">
        <sql>
            CREATE UNIQUE INDEX ux_active_loan_application
                ON loan_application(personal_code)
                WHERE status IN ('NEW','IN_REVIEW');
        </sql>
    </changeSet>

    <changeSet id="2026-04-17 Loan payment schedule table" author="Markus Käpp">
        <createTable tableName="loan_payment_schedule"
                     remarks="Contains amortization schedule entries for approved loan applications">

            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="loan_application_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="payment_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="payment_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <column name="principal" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="interest" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>

            <column name="total_payment" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2026-04-17 Payment schedule foreign key" author="Markus Käpp">
        <addForeignKeyConstraint
                baseTableName="loan_payment_schedule"
                baseColumnNames="loan_application_id"
                referencedTableName="loan_application"
                referencedColumnNames="id"
                constraintName="fk_payment_loan_application"/>
    </changeSet>

    <changeSet id="2026-04-19 Loan status migration" author="Markus Käpp">
        <sql>
            UPDATE loan_application
            SET status = 'STARTED'
            WHERE status = 'NEW';
        </sql>
        <sql>
            DROP INDEX IF EXISTS ux_active_loan_application;
        </sql>
        <sql>
            ALTER TABLE loan_application
            DROP CONSTRAINT IF EXISTS ck_loan_application_status;
        </sql>
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_status
                    CHECK (status IN ('STARTED','IN_REVIEW','APPROVED','REJECTED'));
        </sql>
        <sql>
            CREATE UNIQUE INDEX ux_active_loan_application
                ON loan_application(personal_code)
                WHERE status IN ('STARTED','IN_REVIEW');
        </sql>
    </changeSet>

    <changeSet id="2026-04-19 Loan validation constraints" author="Markus Käpp">
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_period_months
                    CHECK (loan_period_months BETWEEN 6 AND 360);
        </sql>
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_interest_margin
                    CHECK (interest_margin &gt;= 0);
        </sql>
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_base_interest_rate
                    CHECK (base_interest_rate &gt;= 0);
        </sql>
        <sql>
            ALTER TABLE loan_application
                ADD CONSTRAINT ck_loan_application_loan_amount
                    CHECK (loan_amount &gt;= 5000.00);
        </sql>
    </changeSet>

    <changeSet id="2026-04-19 Loan configuration table" author="Markus Käpp">
        <createTable tableName="loan_config"
                     remarks="Stores configurable loan-related parameters such as interest rates and age limits">

            <column name="config_key" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="config_value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="VARCHAR(200)"/>

            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2026-04-20 Loan configuration seed data" author="Markus Käpp">
        <insert tableName="loan_config">
            <column name="config_key" value="euribor_6m"/>
            <column name="config_value" value="3.856"/>
            <column name="description" value="6-month Euribor rate (%)"/>
        </insert>

        <insert tableName="loan_config">
            <column name="config_key" value="customer_max_age"/>
            <column name="config_value" value="70"/>
            <column name="description" value="Maximum customer age in years"/>
        </insert>
    </changeSet>

</databaseChangeLog>