<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

<changeSet id="001" author="dev">
<createTable tableName="loan_application">
    <column name="id" type="UUID">
        <constraints primaryKey="true" nullable="false"/>
    </column>
    <column name="first_name" type="VARCHAR(32)">
        <constraints nullable="false"/>
    </column>
    <column name="last_name" type="VARCHAR(32)">
        <constraints nullable="false"/>
    </column>
    <column name="personal_code" type="VARCHAR(11)">
        <constraints nullable="false"/>
    </column>
    <column name="loan_period_months" type="INTEGER">
        <constraints nullable="false"/>
    </column>
    <column name="interest_margin" type="NUMERIC(5,3)">
        <constraints nullable="false"/>
    </column>
    <column name="base_interest_rate" type="NUMERIC(5,3)">
        <constraints nullable="false"/>
    </column>
    <column name="loan_amount" type="NUMERIC(12,2)">
        <constraints nullable="false"/>
    </column>
    <column name="status" type="VARCHAR(20)">
        <constraints nullable="false"/>
    </column>
    <column name="created_at" type="TIMESTAMP">
        <constraints nullable="false"/>
    </column>
</createTable>
</changeSet>
</databaseChangeLog>